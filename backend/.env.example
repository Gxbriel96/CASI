NODE_ENV=development
PORT=3000

# Database (Local)
DATABASE_URL="postgresql://casi_user:casi_pass@localhost:5432/casi?schema=public"

# Vercel Postgres (Producción)
# Estas variables las genera automáticamente Vercel al crear la base de datos
# POSTGRES_URL=
# POSTGRES_PRISMA_URL=
# POSTGRES_URL_NON_POOLING=
# POSTGRES_USER=
# POSTGRES_HOST=
# POSTGRES_PASSWORD=
# POSTGRES_DATABASE=

# JWT
JWT_SECRET=tu_jwt_secret_aqui_muy_seguro_para_produccion
JWT_REFRESH_SECRET=tu_refresh_secret_aqui_muy_seguro_para_produccion

# JWT Expiration
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (para CORS en producción)
FRONTEND_URL=https://casi-frontend.vercel.app