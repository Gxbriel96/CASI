generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  EMPLEADO
  SOCIO
}

enum ResultadoCalidad {
  APROBADO
  RECHAZADO
}

enum TipoCultivo {
  MAIZ
  TRIGO
  CEBADA
}

enum EspecieFruta {
  MELOCOTON
  NECTARINA
  ALBARICOQUE
  CIRUELA
}

enum Calibre {
  AA
  A
  B
  C
}

model Usuario {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  rol       Rol      @default(SOCIO)
  socioId   String?  @unique
  socio     Socio?   @relation(fields: [socioId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Socio {
  id            String         @id @default(uuid())
  numeroSocio   String         @unique
  nombre        String
  telefono      String?
  email         String?
  direccion     String?
  parcelas      Parcela[]
  entradas      EntradaAlmacen[]
  frutas        FrutaControl[]
  liquidaciones Liquidacion[]
  usuario       Usuario?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Parcela {
  id          String    @id @default(uuid())
  socioId     String
  socio       Socio     @relation(fields: [socioId], references: [id], onDelete: Cascade)
  nombre      String
  hectareas   Float
  ubicacion   String?
  coordenadas String?
  cosechas    Cosecha[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([socioId])
}

model Cosecha {
  id            String          @id @default(uuid())
  parcelaId     String
  parcela       Parcela         @relation(fields: [parcelaId], references: [id], onDelete: Cascade)
  cultivo       TipoCultivo
  rendimiento   Float?
  fechaSiembra  DateTime?
  fechaCosecha  DateTime?
  entradas      EntradaAlmacen[]
  liquidaciones Liquidacion[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([parcelaId])
}

model Silo {
  id          String          @id @default(uuid())
  nombre      String          @unique
  capacidad   Float
  stockActual Float           @default(0)
  cultivo     TipoCultivo?
  entradas    EntradaAlmacen[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model EntradaAlmacen {
  id              String         @id @default(uuid())
  socioId         String
  socio           Socio          @relation(fields: [socioId], references: [id])
  cosechaId       String?
  cosecha         Cosecha?       @relation(fields: [cosechaId], references: [id])
  siloId          String?
  silo            Silo?          @relation(fields: [siloId], references: [id])
  peso            Float
  humedad         Float
  pesoEspecifico  Float
  temperatura     Float
  impurezas       Float
  controlCalidad  ControlCalidad?
  usuarioId       String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([socioId])
  @@index([siloId])
}

model ControlCalidad {
  id              String           @id @default(uuid())
  entradaAlmacenId String          @unique
  entrada         EntradaAlmacen   @relation(fields: [entradaAlmacenId], references: [id], onDelete: Cascade)
  humedad         Float
  pesoEspecifico  Float
  temperatura     Float
  impurezas       Float
  resultado       ResultadoCalidad @default(APROBADO)
  observaciones   String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model FrutaControl {
  id            String       @id @default(uuid())
  socioId       String
  socio         Socio        @relation(fields: [socioId], references: [id])
  especie       EspecieFruta
  variedad      String?
  calibre       Calibre
  azucar        Float
  dureza        Float
  defectos      Float
  observaciones String?
  usuarioId     String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([socioId])
}

model Liquidacion {
  id               String    @id @default(uuid())
  socioId          String
  socio            Socio     @relation(fields: [socioId], references: [id])
  cosechaId       String?
  cosecha          Cosecha?  @relation(fields: [cosechaId], references: [id])
  totalKilos      Float
  precioBase      Float
  importeBruto    Float
  apoyoGobierno  Float     @default(0)
  importeTotal    Float
  fechaLiquidacion DateTime @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([socioId])
}

model Campana {
  id                String    @id @default(uuid())
  nombre            String    @unique
  precioBaseMaiz   Float
  precioBaseTrigo   Float
  porcentajeApoyo   Float     @default(0)
  fechaInicio       DateTime
  fechaFin          DateTime
  activa            Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}